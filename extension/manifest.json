{
  "manifest_version": 3,
  "name": "GOG Games Saver",
  "version": "1.0.0",
  "description": "Save game info (title, tags, torrent + download links, installers, etc.) from gog-games.to and export it to CSV/JSON.",
  "permissions": ["storage", "unlimitedStorage"],
  "host_permissions": ["https://gog-games.to/*"],
  "content_scripts": [
    {
      "matches": ["https://gog-games.to/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "GOG Games Saver",
    "default_popup": "popup.html"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "gog-games-saver@local",
      "strict_min_version": "115.0"
    }
  }
}
